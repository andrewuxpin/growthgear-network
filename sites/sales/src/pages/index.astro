---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "@growthgear/shared/components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { readingTime, countWords, formatDate } from "@growthgear/shared/utils";
import { siteConfig, categories } from "../config";

const articles = await getCollection("articles");
const sortedArticles = articles.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const featuredArticle = sortedArticles[0];
const editorPicks = sortedArticles.slice(1, 4);
const remainingArticles = sortedArticles.slice(4);
---

<BaseLayout
  seo={{
    title: "B2B Sales Strategies & Techniques | Sales Mastery",
    description: siteConfig.seo.defaultDescription,
  }}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 to-accent-50 py-16 md:py-24">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900">
          Master the Art of
          <span class="text-primary-600">Sales Excellence</span>
        </h1>
        <p class="mt-6 text-xl text-gray-600">
          Proven strategies, techniques, and insights to close more deals,
          build stronger relationships, and accelerate your sales career.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          {categories.map((category) => (
            <a
              href={`/${category.slug}`}
              class="btn-secondary"
            >
              {category.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Latest Post + Editor's Picks -->
  {featuredArticle && (
    <section class="container-wide py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <!-- Featured Article (left) -->
        <a href={`/${featuredArticle.data.category}/${featuredArticle.slug}`} class="group block">
          {featuredArticle.data.image && (
            <div class="overflow-hidden rounded-xl mb-4">
              <img
                src={featuredArticle.data.image.src}
                alt={featuredArticle.data.image.alt}
                class="w-full aspect-[16/9] object-cover transition-transform duration-300 group-hover:scale-105"
                loading="eager"
              />
            </div>
          )}
          <span class="text-sm font-semibold uppercase tracking-wide text-primary-600">
            {categories.find((c) => c.slug === featuredArticle.data.category)?.name || featuredArticle.data.category}
          </span>
          <h2 class="mt-2 text-2xl md:text-3xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors">
            {featuredArticle.data.title}
          </h2>
          <p class="mt-3 text-gray-600 line-clamp-3">{featuredArticle.data.description}</p>
          <div class="mt-4 flex items-center gap-3 text-sm text-gray-500">
            {featuredArticle.data.author.avatar && (
              <img src={featuredArticle.data.author.avatar} alt={featuredArticle.data.author.name} class="w-7 h-7 rounded-full" />
            )}
            <span>{featuredArticle.data.author.name}</span>
            <span class="text-gray-300">&bull;</span>
            <span>{readingTime(countWords(featuredArticle.body))} min read</span>
          </div>
        </a>

        <!-- Editor's Picks (right) -->
        <div class="space-y-6">
          <h3 class="text-sm font-semibold uppercase tracking-wider text-gray-400">Editor's Picks</h3>
          {editorPicks.map((article) => (
            <a href={`/${article.data.category}/${article.slug}`} class="group flex gap-4">
              {article.data.image && (
                <div class="shrink-0 w-28 h-20 overflow-hidden rounded-lg">
                  <img
                    src={article.data.image.src}
                    alt={article.data.image.alt}
                    class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="min-w-0">
                <span class="text-xs font-semibold uppercase tracking-wide text-primary-600">
                  {categories.find((c) => c.slug === article.data.category)?.name || article.data.category}
                </span>
                <h4 class="mt-1 text-sm font-bold text-gray-900 group-hover:text-primary-600 transition-colors line-clamp-2">
                  {article.data.title}
                </h4>
                <p class="mt-1 text-xs text-gray-500">{readingTime(countWords(article.body))} min read</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Mid-page CTA -->
  <section class="bg-gradient-to-r from-primary-600 to-accent-600 py-12">
    <div class="container-wide text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white">Ready to Supercharge Your Sales?</h2>
      <p class="mt-3 text-lg text-white/80 max-w-2xl mx-auto">Book a free strategy call and discover how AI-powered tools can help you close more deals.</p>
      <a
        href="#"
        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/abe-growthgear/free-strategy-call?hide_gdpr_banner=1'});return false;"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-primary-700 shadow-lg transition-transform hover:scale-105 cursor-pointer"
      >
        Book Your Free Call
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Category Filter + Search + Article Grid -->
  <section class="container-wide py-12">
    <!-- Filter Bar -->
    <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-8">
      <div class="flex flex-wrap gap-2" id="category-filters">
        <button
          class="px-4 py-2 rounded-full text-sm font-medium bg-primary-500 text-white transition-colors cursor-pointer"
          data-filter="all"
        >
          All
        </button>
        {categories.map((cat) => (
          <button
            class="px-4 py-2 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200 transition-colors cursor-pointer"
            data-filter={cat.slug}
          >
            {cat.name}
          </button>
        ))}
      </div>
      <div class="sm:ml-auto">
        <input
          type="search"
          placeholder="Search articles..."
          id="article-search"
          class="w-full sm:w-64 rounded-lg border border-gray-300 px-4 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500"
        />
      </div>
    </div>

    <!-- Article Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="article-grid">
      {remainingArticles.map((article) => (
        <div
          data-article-card
          data-category={article.data.category}
          data-title={article.data.title.toLowerCase()}
          data-description={article.data.description.toLowerCase()}
        >
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/${article.data.category}/${article.slug}`}
            image={article.data.image}
            date={article.data.publishedAt}
            category={categories.find((c) => c.slug === article.data.category)?.name}
            categoryHref={`/${article.data.category}`}
            readingTime={readingTime(countWords(article.body))}
          />
        </div>
      ))}

      <!-- Newsletter Card -->
      <div class="rounded-xl border border-gray-200 bg-gradient-to-br from-primary-50 to-accent-50 p-8 flex flex-col justify-center" data-newsletter-card>
        <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-primary-100">
          <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
          </svg>
        </div>
        <h3 class="text-lg font-bold text-gray-900">Stay in the Loop</h3>
        <p class="mt-2 text-sm text-gray-600">Get the latest sales insights and strategies delivered to your inbox weekly.</p>
        <form class="mt-4 space-y-3" action="#" method="POST">
          <input
            type="email"
            placeholder="your@email.com"
            required
            class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500"
          />
          <button
            type="submit"
            class="w-full rounded-lg bg-primary-600 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-primary-700"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    <!-- Empty State -->
    <div class="hidden py-16 text-center" id="empty-state">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
      </svg>
      <h3 class="mt-4 text-lg font-semibold text-gray-900">No articles found</h3>
      <p class="mt-2 text-sm text-gray-500">Try adjusting your search or filter to find what you're looking for.</p>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="bg-gray-50 py-16">
    <div class="container-wide">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Browse by Category</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {categories.map((category) => (
          <a
            href={`/${category.slug}`}
            class="group p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-lg transition-all"
          >
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary-600">
              {category.name}
            </h3>
            <p class="mt-2 text-sm text-gray-600">{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CollectionPage JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    name: `${siteConfig.site.name} - Articles`,
    url: siteConfig.seo.siteUrl,
    mainEntity: {
      "@type": "ItemList",
      itemListElement: sortedArticles.map((a, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: `${siteConfig.seo.siteUrl}/${a.data.category}/${a.slug}`,
        name: a.data.title,
      })),
    },
  })} />
</BaseLayout>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const filterBtns = document.querySelectorAll<HTMLButtonElement>("[data-filter]");
    const searchInput = document.getElementById("article-search") as HTMLInputElement;
    const cards = document.querySelectorAll<HTMLElement>("[data-article-card]");
    const newsletterCard = document.querySelector<HTMLElement>("[data-newsletter-card]");
    const emptyState = document.getElementById("empty-state");
    const grid = document.getElementById("article-grid");

    let activeCategory = "all";

    function applyFilters() {
      const query = searchInput?.value.toLowerCase().trim() || "";
      let visibleCount = 0;

      cards.forEach((card) => {
        const cat = card.getAttribute("data-category") || "";
        const title = card.getAttribute("data-title") || "";
        const desc = card.getAttribute("data-description") || "";

        const matchesCategory = activeCategory === "all" || cat === activeCategory;
        const matchesSearch = !query || title.includes(query) || desc.includes(query);

        const visible = matchesCategory && matchesSearch;
        card.style.display = visible ? "" : "none";
        if (visible) visibleCount++;
      });

      if (newsletterCard) {
        newsletterCard.style.display = (activeCategory === "all" && !query) ? "" : "none";
      }

      if (emptyState) {
        emptyState.style.display = visibleCount === 0 ? "block" : "none";
      }
      if (grid) {
        grid.style.display = visibleCount === 0 && !newsletterCard ? "none" : "";
      }
    }

    filterBtns.forEach((btn) => {
      btn.addEventListener("click", () => {
        activeCategory = btn.getAttribute("data-filter") || "all";
        filterBtns.forEach((b) => {
          const isActive = b === btn;
          b.classList.toggle("bg-primary-500", isActive);
          b.classList.toggle("text-white", isActive);
          b.classList.toggle("bg-gray-100", !isActive);
          b.classList.toggle("text-gray-600", !isActive);
        });
        applyFilters();
      });
    });

    searchInput?.addEventListener("input", applyFilters);
  });
</script>
