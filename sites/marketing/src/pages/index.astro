---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArticleCard from "@growthgear/shared/components/ArticleCard.astro";
import { getCollection } from "astro:content";
import { readingTime, countWords } from "@growthgear/shared/utils";
import { siteConfig, categories } from "../config";

const articles = await getCollection("articles");
const sortedArticles = articles.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);

const featuredArticle = sortedArticles[0];
const recentArticles = sortedArticles.slice(1, 7);
---

<BaseLayout
  seo={{
    title: `${siteConfig.site.name} - ${siteConfig.seo.defaultDescription}`,
    description: siteConfig.seo.defaultDescription,
  }}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-50 to-accent-50 py-16 md:py-24">
    <div class="container-wide">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900">
          Your Edge in
          <span class="text-primary-600">Digital Marketing</span>
        </h1>
        <p class="mt-6 text-xl text-gray-600">
          Cutting-edge strategies, growth hacks, and actionable insights
          to scale your marketing and drive real business results.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          {categories.map((category) => (
            <a
              href={`/${category.slug}`}
              class="btn-secondary"
            >
              {category.name}
            </a>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Article -->
  {featuredArticle && (
    <section class="container-wide py-12">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Featured</h2>
      <ArticleCard
        title={featuredArticle.data.title}
        description={featuredArticle.data.description}
        href={`/${featuredArticle.data.category}/${featuredArticle.slug}`}
        image={featuredArticle.data.image}
        date={featuredArticle.data.publishedAt}
        category={categories.find((c) => c.slug === featuredArticle.data.category)?.name}
        categoryHref={`/${featuredArticle.data.category}`}
        readingTime={readingTime(countWords(featuredArticle.body))}
        featured={true}
      />
    </section>
  )}

  <!-- Recent Articles -->
  {recentArticles.length > 0 && (
    <section class="container-wide py-12 border-t border-gray-100">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Recent Articles</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {recentArticles.map((article) => (
          <ArticleCard
            title={article.data.title}
            description={article.data.description}
            href={`/${article.data.category}/${article.slug}`}
            image={article.data.image}
            date={article.data.publishedAt}
            category={categories.find((c) => c.slug === article.data.category)?.name}
            categoryHref={`/${article.data.category}`}
            readingTime={readingTime(countWords(article.body))}
          />
        ))}
      </div>
    </section>
  )}

  <!-- CTA Banner -->
  <section class="bg-gradient-to-r from-primary-600 to-accent-600 py-12">
    <div class="container-wide text-center">
      <h2 class="text-2xl md:text-3xl font-bold text-white">Ready to Scale Your Marketing?</h2>
      <p class="mt-3 text-lg text-white/80 max-w-2xl mx-auto">Book a free strategy call and learn how AI can amplify your marketing results.</p>
      <a
        href=""
        onclick="Calendly.initPopupWidget({url: 'https://calendly.com/abe-growthgear/free-strategy-call?hide_gdpr_banner=1'});return false;"
        class="mt-6 inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-primary-700 shadow-lg transition-transform hover:scale-105 cursor-pointer"
      >
        Book Your Free Call
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Categories -->
  <section class="bg-gray-50 py-16">
    <div class="container-wide">
      <h2 class="text-2xl font-bold text-gray-900 mb-8">Browse by Category</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {categories.map((category) => (
          <a
            href={`/${category.slug}`}
            class="group p-6 bg-white rounded-xl border border-gray-200 hover:border-primary-300 hover:shadow-lg transition-all"
          >
            <h3 class="text-lg font-bold text-gray-900 group-hover:text-primary-600">
              {category.name}
            </h3>
            <p class="mt-2 text-sm text-gray-600">{category.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
