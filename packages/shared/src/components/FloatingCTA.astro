---
interface Props {
  bookingTitle?: string;
  bookingDescription?: string;
  newsletterTitle?: string;
  newsletterDescription?: string;
}

const {
  bookingTitle = "Book Your Free Strategy Call",
  bookingDescription = "Discover how AI can transform your business. Get a personalised roadmap in a free 30-minute consultation.",
  newsletterTitle = "Get AI Insights Weekly",
  newsletterDescription = "Join 2,000+ business owners getting actionable AI tips every Thursday.",
} = Astro.props;
---

<aside class="space-y-6">
  <!-- Book a Call CTA -->
  <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-primary-50">
      <svg class="h-6 w-6 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-gray-900">{bookingTitle}</h3>
    <p class="mt-2 text-sm text-gray-600">{bookingDescription}</p>
    <a
      href=""
      onclick="Calendly.initPopupWidget({url: 'https://calendly.com/abe-growthgear/free-strategy-call?hide_gdpr_banner=1'});return false;"
      class="mt-4 block w-full rounded-lg bg-primary-600 px-4 py-3 text-center text-sm font-semibold text-white transition-colors hover:bg-primary-700 cursor-pointer"
    >
      Schedule Your Call
      <svg class="ml-1 inline-block h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </a>
  </div>

  <!-- Newsletter Signup -->
  <div class="rounded-xl border border-gray-200 bg-gray-50 p-6">
    <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-lg bg-accent-50">
      <svg class="h-6 w-6 text-accent-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75" />
      </svg>
    </div>
    <h3 class="text-lg font-bold text-gray-900">{newsletterTitle}</h3>
    <p class="mt-2 text-sm text-gray-600">{newsletterDescription}</p>
    <form class="mt-4 space-y-3" action="#" method="POST">
      <input
        type="email"
        placeholder="your@email.com"
        required
        class="w-full rounded-lg border border-gray-300 px-4 py-2.5 text-sm text-gray-900 placeholder-gray-400 focus:border-primary-500 focus:outline-none focus:ring-1 focus:ring-primary-500"
      />
      <button
        type="submit"
        class="w-full rounded-lg bg-gray-900 px-4 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-gray-800"
      >
        Subscribe
      </button>
    </form>
  </div>

  <!-- Quick Links -->
  <div class="rounded-xl border border-gray-200 bg-white p-6">
    <h3 class="text-sm font-semibold uppercase tracking-wide text-gray-500">Explore</h3>
    <nav class="mt-3 space-y-2">
      <a href="/" class="block text-sm text-gray-700 hover:text-primary-600 transition-colors">All Articles</a>
      <a href="https://growthgear.com.au/services/ai-strategy-implementation" class="block text-sm text-gray-700 hover:text-primary-600 transition-colors">AI Strategy Services</a>
      <a href="https://growthgear.com.au/about" class="block text-sm text-gray-700 hover:text-primary-600 transition-colors">About GrowthGear</a>
    </nav>
  </div>
</aside>
